# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5435
DB_USER=mandi
DB_PASSWORD=mandi
DB_NAME=mandi_erp

# Auth
JWT_SECRET=dev-super-secret-change-me-in-production
JWT_EXPIRES_IN=7d

# OTP (dev mode: OTP is returned in the response & logged instead of sent via SMS)
OTP_DEV_MODE=true
OTP_TTL_SECONDS=300

# Dashboard: serve deterministic demo data until transactional modules land
DASHBOARD_DEMO=true
